{
  "db_name": "PostgreSQL",
  "query": "SELECT rt.id, rt.user_id, u.external_id AS user_external_id, u.role AS user_role, rt.family_id, rt.token_hash, rt.superseded_at, rt.revoked_at, rt.expires_at, rt.created_at FROM refresh_tokens rt JOIN users u ON rt.user_id = u.id WHERE rt.family_id = $1 AND rt.superseded_at IS NULL AND rt.revoked_at IS NULL AND rt.expires_at > NOW() ORDER BY rt.created_at DESC LIMIT 1",
