  "db_name": "PostgreSQL",
  "query": "SELECT uc.id AS credential_id,\n                    u.id AS user_internal_id,\n                    u.external_id AS user_external_id,\n                    u.email AS \"email!\",\n                    u.role,\n                    uc.password_hash,\n                    uc.failed_attempts,\n                    uc.locked_until\n             FROM user_credentials uc\n             JOIN users u ON uc.user_id = u.id\n             WHERE u.email = $1",
